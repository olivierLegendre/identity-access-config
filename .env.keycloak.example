# Keycloak baseline render input (no secrets)
KEYCLOAK_REALM=iot-platform
OPERATOR_UI_REDIRECT_URI=http://localhost:5173/*
OPERATOR_UI_WEB_ORIGIN=http://localhost:5173

# Optional metadata for runbook commands
KEYCLOAK_CONTAINER=keycloak-wave1
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local-only
KEYCLOAK_HTTP_PORT=18080
